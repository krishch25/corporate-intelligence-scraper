# Environment
ENV=dev

# Database (default SQLite for local dev)
DATABASE_URL=sqlite:///./taxonomy.db

# For PostgreSQL:
# DATABASE_URL=postgresql://user:pass@localhost:5432/taxonomy

# ChromaDB
CHROMA_PERSIST_PATH=./chroma_data

# LLM (optional; set at least one for agents)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# LLM provider and models
LLM_PROVIDER=openrouter
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-latest
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
